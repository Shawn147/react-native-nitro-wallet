{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["wallet"],
  "ios": {
    "iosModuleName": "NitroWallet"
  },
  "android": {
    "androidNamespace": ["wallet"],
    "androidCxxLibName": "NitroWallet"
  },
  "autolinking": {
    "WalletManager": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridWalletManager"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridWalletManager"
      }
    },
    "WalletPassKit": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridWalletPassKit"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridWalletPassKit"
      }
    }
  },
  "ignorePaths": ["**/node_modules"],
  "gitAttributesGeneratedFlag": false
}
